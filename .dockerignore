# Donnees personnelles / generees : ne doivent jamais finir dans l'image
web_runs/
releves_generes/
web_runs/**
releves_generes/**
modeles/

# Tout fichier Excel/Word est exclu du build, ou qu'il se trouve dans le
# projet : l'image n'en a jamais besoin (modeles fournis via un volume,
# donnees d'entree deposees via l'upload web). Empeche toute donnee
# personnelle d'etudiant de finir dans l'image, quel que soit son nom.
*.xlsx
*.docx

# Git / IDE / outils Claude
.git/
.gitignore
.claude/

# Python
__pycache__/
*.pyc
*.pyo

# Fichiers Windows specifiques (inutiles en conteneur Linux)
*.bat
*.vbs
install.ps1

# Documentation (non necessaire a l'execution)
MEMOIRE_PROJET.md
README.md
