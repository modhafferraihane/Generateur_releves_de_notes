# Donnees personnelles / generees : ne doivent jamais finir dans l'image
web_runs/
releves_generes/
web_runs/**
releves_generes/**

# Tout fichier Excel/Word est exclu du build, ou qu'il se trouve dans le
# projet (donnees d'entree deposees via l'upload web, PV reels a la racine).
# Empeche toute donnee personnelle d'etudiant de finir dans l'image, quel que
# soit son nom.
*.xlsx
*.docx

# ...SAUF les gabarits vierges du dossier modeles/ (Exemple*.xlsx / AR*.docx),
# dont l'app a besoin au demarrage : on les embarque dans l'image pour qu'un
# simple `docker run` fonctionne sans montage de volume. Ces gabarits ne
# contiennent aucune donnee d'etudiant (anonymises). Un volume monte sur
# /app/modeles reste possible pour surcharger avec un gabarit personnalise.
!modeles/*.xlsx
!modeles/*.docx

# Git / IDE / outils Claude
.git/
.gitignore
.claude/

# Python
__pycache__/
*.pyc
*.pyo

# Fichiers Windows specifiques (inutiles en conteneur Linux)
*.bat
*.vbs
install.ps1

# Documentation (non necessaire a l'execution)
MEMOIRE_PROJET.md
README.md
